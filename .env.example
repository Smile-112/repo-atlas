# GitHub integration runs only on the Repo Atlas server.
# Create a fine-grained, read-only token — never use a VITE_ prefix.
GITHUB_TOKEN=github_pat_<replace-with-your-full-token>
# One owner is selected and shown at a time in the importer dropdown.
GITHUB_OWNERS=<your-github-login>,<another-owner-or-organisation>
# HTTP port inside the container and on the host in compose.yaml.
PORT=8080
